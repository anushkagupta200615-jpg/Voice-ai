# ── LLM (reasoning) ─────────────────────────────────────────────
# Any "provider:model" string supported by LangChain's init_chat_model.
# Examples:
#   groq:openai/gpt-oss-120b           (fast + free tier, reliable tool calling)
#   groq:llama-3.3-70b-versatile       (fast + free tier, flakier with tools)
#   anthropic:claude-sonnet-5          (needs ANTHROPIC_API_KEY + langchain-anthropic)
#   openai:gpt-4o-mini                 (needs OPENAI_API_KEY + langchain-openai)
LLM_MODEL=groq:openai/gpt-oss-120b
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── STT (speech → text) ────────────────────────────────────────
# Options: groq (Whisper via Groq, reuses GROQ_API_KEY) | deepgram
STT_PROVIDER=groq
DEEPGRAM_API_KEY=

# ── TTS (text → speech) ────────────────────────────────────────
# Options: edge (free, no key needed) | elevenlabs
TTS_PROVIDER=edge
EDGE_TTS_VOICE=en-US-AriaNeural
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Agent persona / domain plugin ──────────────────────────────
# Name of a module in backend/voice_core/plugins/ that provides
# SYSTEM_PROMPT and get_tools(). Swap this per hackathon theme.
AGENT_PLUGIN=demo

# Optional: override the plugin's system prompt without code changes
# SYSTEM_PROMPT=You are a helpful medical assistant...
